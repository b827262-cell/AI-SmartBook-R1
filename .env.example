# ============================================================
# AI-SmartBook-R1 root env example
# Do not commit real .env files.
# ============================================================

NODE_ENV=development

# Admin AI provider. Default mock works without API key.
AI_PROVIDER=mock
AI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# SQLite
DATABASE_URL=file:./data/ai-smartbook-r1.db
SQLITE_PATH=./data/ai-smartbook-r1.db

# Student runtime
STU_RUNTIME_MODE=sqlite-api
STU_DB_PATH=./data/student.db
STU_API_PORT=4310
STU_PUBLIC_DIR=./apps/AI-Stu-R1/dist
STU_READONLY_MODE=true
STU_CHAT_MODE=keyword
